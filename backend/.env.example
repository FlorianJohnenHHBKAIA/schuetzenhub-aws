# ============================================================
# SchützenConnect Backend – Umgebungsvariablen
# Kopiere diese Datei zu ".env" und passe die Werte an.
# ============================================================

# PostgreSQL Verbindung (lokal)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=schuetzenhub
DB_USER=postgres
DB_PASSWORD=dein_passwort_hier

# JWT Secret – bitte einen langen, zufälligen String verwenden!
# Tipp: openssl rand -hex 64
JWT_SECRET=BITTE_AENDERN_langer_geheimer_schluessel_hier

# Server Port
PORT=5000

# CORS – Frontend-URL
FRONTEND_URL=http://localhost:5173

# Datei-Upload Verzeichnis (relativ zum backend-Ordner)
UPLOAD_DIR=uploads

# Maximale Dateigröße in MB
MAX_FILE_SIZE_MB=10

# ============================================================
# FÜR SPÄTERE AWS-NUTZUNG – hier auskommentiert lassen:
# ============================================================
# AWS_REGION=eu-central-1
# AWS_S3_BUCKET=schuetzenhub-uploads
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# USE_S3=false
